{
  "name": "react-native-cas",
  "version": "4.6.5",
  "description": "The CAS.AI React Native plugin allows you to easily monetize your apps for iOS and Android using lot of Ads SDKs in mediation.",
  "author": "Clever Ads Solutions LTD <support@cas.ai> (https://cas.ai)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cleveradssolutions/CAS-ReactNative.git"
  },
  "bugs": {
    "url": "https://github.com/cleveradssolutions/CAS-ReactNative/issues"
  },
  "homepage": "https://docs.page/cleveradssolutions/docs/ReactNative",
  "keywords": [
    "react",
    "react-native",
    "ads",
    "mobile",
    "mediation",
    "ios",
    "android",
    "admob"
  ],
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index",
  "source": "src/index",
  "types": "lib/typescript/index.d.ts",
  "files": [
    "/lib/",
    "/src/",
    "/android/",
    "/ios/",
    "/plugin/",
    "/package.json",
    "/app.plugin.js",
    "/babel.config.js",
    "/react-native-cas.podspec",
    "/react-native.config.js",
    "!ios/build",
    "!android/app",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties"
  ],
  "scripts": {
    "clean": "rimraf build && rimraf android/build && rimraf android/app/build && rimraf example/ios/build && rimraf lib && rimraf example/android/build",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx}'",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "codegen": "react-native codegen",
    "prepare": "bob build && rimraf plugin/build && tsc -p plugin/tsconfig.json",
    "test:android": "cd example/android && ./gradlew assembleDebug --no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a",
    "test:ios": "cd example/ios && pod update --no-repo-update && xcodebuild -workspace CASExample.xcworkspace -scheme CASExample -configuration Debug -sdk iphonesimulator CC=clang CPLUSPLUS=clang++ LD=clang LDPLUSPLUS=clang++ GCC_OPTIMIZATION_LEVEL=0 GCC_PRECOMPILE_PREFIX_HEADER=YES ASSETCATALOG_COMPILER_OPTIMIZATION=time DEBUG_INFORMATION_FORMAT=dwarf COMPILER_INDEX_STORE_ENABLE=NO",
    "release": "npm publish --access public"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@expo/config-plugins": "^55.0.0",
    "@react-native-community/cli": "^20.0.0",
    "@types/react": "19.2.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "expo": "^55.0.0",
    "expo-module-scripts": "^55.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-native-builder-bob": "0.40.18",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "expo": ">=47.0.0",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "codegenConfig": {
    "name": "RNCASMobileAdsSpec",
    "type": "all",
    "jsSrcsDir": "./src/modules",
    "ios": {
      "libraryName": "CAS",
      "podName": "react-native-cas",
      "moduleName": "CASMobileAds",
      "componentProvider": {
        "CASAdView": "RNCASBannerAdView",
        "CASNativeAdView": "RNCASNativeAdView",
        "CASNativeAssetView": "RNCASNativeAssetView"
      }
    },
    "android": {
      "javaPackageName": "com.cleveradssolutions.plugin.reactnative"
    }
  }
}
